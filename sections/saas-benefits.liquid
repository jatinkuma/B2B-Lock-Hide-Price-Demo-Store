{%- style -%}
  .saas-benefits {
    padding: 88px 0 !important;
    background: #ffffff !important;
  }
  .saas-benefits-wrap {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 0.95fr);
    gap: 28px;
    align-items: start;
  }
  .saas-benefits-copy {
    background: #ffffff;
    border: 1px solid #dbeafe;
    border-radius: 30px;
    padding: 40px;
    box-shadow: 0 20px 54px rgba(15, 23, 42, 0.06);
  }
  .saas-benefits-label {
    display: inline-block;
    margin-bottom: 16px;
    color: #1d4ed8;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .saas-benefits-title {
    margin: 0 0 18px;
    font-size: clamp(2.1rem, 4vw, 3.4rem);
    line-height: 1.08;
    letter-spacing: -0.04em;
    color: #0f172a;
  }
  .saas-benefits-text {
    margin: 0 0 22px;
    color: #475569;
    font-size: 18px;
    line-height: 1.75;
  }
  .saas-benefits-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 12px;
  }
  .saas-benefits-list li {
    display: flex;
    gap: 12px;
    color: #0f172a;
    font-size: 15px;
    line-height: 1.6;
    font-weight: 600;
  }
  .saas-benefits-list li::before {
    content: '✓';
    width: 22px;
    height: 22px;
    border-radius: 7px;
    background: #2563eb;
    color: #ffffff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    font-size: 13px;
    font-weight: 800;
    margin-top: 1px;
  }
  .saas-benefits-panel {
    background: linear-gradient(135deg, #0f172a, #162033);
    border-radius: 30px;
    padding: 24px;
    box-shadow: 0 24px 60px rgba(15, 23, 42, 0.14);
  }
  .benefit-card {
    background: #ffffff;
    border-radius: 22px;
    padding: 22px;
    box-shadow: 0 16px 40px rgba(15, 23, 42, 0.14);
  }
  .benefit-card + .benefit-card {
    margin-top: 16px;
  }
  .benefit-card strong {
    display: block;
    margin-bottom: 8px;
    color: #0f172a;
    font-size: 18px;
  }
  .benefit-card span {
    display: block;
    color: #475569;
    font-size: 14px;
    line-height: 1.65;
  }
  @media screen and (max-width: 989px) {
    .saas-benefits-wrap {
      grid-template-columns: 1fr;
    }
  }
  @media screen and (max-width: 749px) {
    .saas-benefits {
      padding: 72px 0 !important;
    }
    .saas-benefits-copy,
    .saas-benefits-panel {
      padding: 24px;
      border-radius: 24px;
    }
  }
{%- endstyle -%}

<section class="saas-benefits">
  <div class="page-width">
    <div class="saas-benefits-wrap">
      <div class="saas-benefits-copy">
        <div class="saas-benefits-label">Why Merchants Use It</div>
        <h2 class="saas-benefits-title">Built for wholesale stores that need tighter storefront control</h2>
        <p class="saas-benefits-text">ESTS B2B Lock & Hide Price helps merchants run cleaner B2B and private-catalog experiences without exposing the wrong prices to the wrong audience.</p>
        <ul class="saas-benefits-list">
          <li>No-code setup for hidden pricing and protected storefront content.</li>
          <li>Flexible targeting using guest, login, tag and buyer-access conditions.</li>
          <li>Supports passcode, secret-link and request-based approval workflows.</li>
        </ul>
      </div>

      <div class="saas-benefits-panel">
        <div class="benefit-card">
          <strong>No-code setup</strong>
          <span>Create lock rules, choose your audience and launch protected views without custom development work.</span>
        </div>
        <div class="benefit-card">
          <strong>Precise customer targeting</strong>
          <span>Show prices, products and pages only when the customer state or tag matches your B2B access logic.</span>
        </div>
        <div class="benefit-card">
          <strong>Private sales workflows</strong>
          <span>Use secret links, passcodes and request forms to support wholesaler onboarding and gated catalogs.</span>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SaaS Benefits",
  "tag": "section",
  "class": "section",
  "presets": [
    {
      "name": "SaaS Benefits"
    }
  ]
}
{% endschema %}
