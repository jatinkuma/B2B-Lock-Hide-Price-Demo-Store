{%- style -%}
  .banner.premium-hero {
    min-height: 100vh !important;
    background: var(--gradient-hero) !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    text-align: center !important;
    padding: 140px 20px 100px !important;
    position: relative;
    overflow: hidden;
  }

  .banner.premium-hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at 50% 20%, rgba(99, 102, 241, 0.05), transparent 50%);
    transform: translateX(-50%);
    pointer-events: none;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 20px;
    background: rgba(99, 102, 241, 0.05);
    border: 1px solid rgba(99, 102, 241, 0.1);
    border-radius: var(--radius-pill);
    font-size: 14px;
    font-weight: 500;
    color: var(--color-brand-1);
    margin-bottom: 32px;
    animation: fadeInUp 0.8s ease forwards;
  }

  .hero-badge::before {
    content: '';
    width: 6px;
    height: 6px;
    background: var(--color-brand-1);
    border-radius: 50%;
    box-shadow: 0 0 10px var(--color-brand-1);
  }

  .banner__heading {
    font-size: var(--text-hero) !important;
    font-weight: 800 !important;
    letter-spacing: -0.04em !important;
    line-height: 1.05 !important;
    color: var(--text-primary) !important;
    max-width: 900px !important;
    margin: 0 auto 24px !important;
    animation: fadeInUp 0.8s ease 0.1s forwards;
    opacity: 0;
  }

  .banner__heading .highlight {
    background: var(--text-vibrant);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-style: italic;
  }

  .banner__text {
    font-size: 20px !important;
    color: var(--text-secondary) !important;
    max-width: 600px !important;
    margin: 0 auto 48px !important;
    line-height: 1.6 !important;
    animation: fadeInUp 0.8s ease 0.2s forwards;
    opacity: 0;
  }

  .banner__buttons {
    display: flex !important;
    gap: 20px !important;
    justify-content: center !important;
    animation: fadeInUp 0.8s ease 0.3s forwards;
    opacity: 0;
  }

  .button--primary-hero {
    background: var(--gradient-brand) !important;
    color: #ffffff !important;
    border: none !important;
    padding: 18px 36px !important;
    border-radius: var(--radius-pill) !important;
    font-weight: 600 !important;
    font-size: 16px !important;
    display: flex !important;
    align-items: center !important;
    gap: 10px !important;
    transition: var(--transition-spring) !important;
  }

  .button--primary-hero:hover {
    transform: translateY(-4px) scale(1.02);
    box-shadow: 0 15px 30px rgba(99, 102, 241, 0.2);
  }

  .button--secondary-hero {
    background: transparent !important;
    color: var(--text-primary) !important;
    border: 1px solid #e2e8f0 !important;
    padding: 18px 36px !important;
    border-radius: var(--radius-pill) !important;
    font-weight: 600 !important;
    font-size: 16px !important;
    display: flex !important;
    align-items: center !important;
    gap: 10px !important;
    transition: var(--transition-spring) !important;
  }

  .button--secondary-hero:hover {
    background: #f8fafc !important;
    border-color: #cbd5e1 !important;
    transform: translateY(-4px);
  }
{%- endstyle -%}

<div id="Banner-{{ section.id }}" class="banner premium-hero">
  <div class="banner__content page-width">
    <div class="hero-badge">
      <span>Trusted by merchants worldwide</span>
    </div>
    
    <h2 class="banner__heading">
      Supercharge Your <span class="highlight">E-commerce</span> Growth Today
    </h2>

    <div class="banner__text">
      The all-in-one toolkit designed to automate your workflows, increase average order value, and scale your brand effortlessly.
    </div>

    {% comment %} <div class="banner__buttons">
      <a href="/collections/all" class="button--primary-hero">
        Get Started Free <span>→</span>
      </a>
      <a href="#demo" class="button--secondary-hero">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
        Watch Demo
      </a>
    </div> {% endcomment %}
  </div>
</div>


