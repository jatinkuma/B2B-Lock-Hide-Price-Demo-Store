{%- style -%}
  .saas-cta {
    padding: 110px 0 !important;
    background: #ffffff !important;
  }
  .saas-cta-container {
    border-radius: 34px;
    overflow: hidden;
    background: linear-gradient(135deg, #0f172a, #1d4ed8 60%, #3b82f6);
    padding: 68px 56px;
    position: relative;
    box-shadow: 0 30px 70px rgba(37, 99, 235, 0.22);
  }
  .saas-cta-container::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 15% 20%, rgba(255, 255, 255, 0.14), transparent 26%),
      radial-gradient(circle at 85% 30%, rgba(255, 255, 255, 0.1), transparent 22%);
    pointer-events: none;
  }
  .saas-cta-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 26px;
    align-items: end;
  }
  .saas-cta-label {
    display: inline-block;
    margin-bottom: 16px;
    color: #bfdbfe;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .saas-cta-heading {
    margin: 0 0 16px;
    color: #ffffff !important;
    font-size: clamp(2.5rem, 5vw, 4.5rem) !important;
    line-height: 1.02 !important;
    letter-spacing: -0.05em !important;
    max-width: 760px;
  }
  .saas-cta-text {
    margin: 0;
    color: rgba(255, 255, 255, 0.84) !important;
    font-size: 19px !important;
    line-height: 1.7 !important;
    max-width: 660px;
  }
  .button--cta {
    align-self: center;
    min-height: 58px;
    padding: 18px 30px !important;
    border-radius: 16px !important;
    background: #ffffff !important;
    color: #1d4ed8 !important;
    font-size: 17px !important;
    font-weight: 800 !important;
    text-decoration: none !important;
    display: inline-flex !important;
    align-items: center !important;
    gap: 10px !important;
    box-shadow: 0 18px 44px rgba(15, 23, 42, 0.14);
  }
  .button--cta:hover {
    transform: translateY(-3px);
  }
  @media screen and (max-width: 989px) {
    .saas-cta-grid {
      grid-template-columns: 1fr;
      align-items: start;
    }
  }
  @media screen and (max-width: 749px) {
    .saas-cta {
      padding: 76px 0 !important;
    }
    .saas-cta-container {
      padding: 34px 24px;
      border-radius: 26px;
    }
  }
{%- endstyle -%}

<section class="saas-cta">
  <div class="page-width">
    <div class="saas-cta-container">
      <div class="saas-cta-grid">
        <div>
          <div class="saas-cta-label">Shopify App Store</div>
          <h2 class="saas-cta-heading">Control pricing visibility before the wrong buyers see it</h2>
          <p class="saas-cta-text">Use ESTS B2B Lock & Hide Price to protect wholesale pricing, private pages and B2B product access with a cleaner storefront experience.</p>
        </div>
        <a href="https://apps.shopify.com/login-to-see-price" class="button--cta">
          Install App <span>&rarr;</span>
        </a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SaaS CTA Section",
  "tag": "section",
  "class": "section",
  "presets": [
    {
      "name": "SaaS CTA Section"
    }
  ]
}
{% endschema %}
