{%- style -%}
  .saas-showcase {
    padding: 110px 0 !important;
    background: #ffffff !important;
  }
  .saas-showcase-stack {
    display: grid;
    gap: 28px;
  }
  .saas-usecase {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(320px, 0.92fr);
    align-items: center;
    border-radius: 34px;
    overflow: hidden;
    background: linear-gradient(90deg, #f8fbff 0 62%, #111827 62% 100%);
    box-shadow: 0 28px 70px rgba(15, 23, 42, 0.08);
    border: 1px solid #dbeafe;
  }
  .saas-usecase:nth-child(even) {
    grid-template-columns: minmax(320px, 0.92fr) minmax(0, 1.08fr);
    background: linear-gradient(90deg, #111827 0 38%, #f8fbff 38% 100%);
  }
  .saas-usecase-media {
    padding: 34px;
  }
  .saas-usecase-demo {
    background: #ffffff;
    border-radius: 26px;
    border: 1px solid #dbeafe;
    box-shadow: 0 20px 48px rgba(15, 23, 42, 0.08);
    overflow: hidden;
  }
  .demo-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    padding: 18px 22px;
    background: #eff6ff;
    border-bottom: 1px solid #dbeafe;
  }
  .demo-title {
    font-size: 17px;
    font-weight: 800;
    color: #0f172a;
  }
  .demo-pill {
    padding: 8px 12px;
    border-radius: 999px;
    background: #dbeafe;
    color: #1d4ed8;
    font-size: 12px;
    font-weight: 700;
  }
  .demo-body {
    padding: 24px;
    background: linear-gradient(180deg, #ffffff, #f8fbff);
  }
  .mini-row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }
  .mini-box {
    padding: 16px;
    border-radius: 16px;
    border: 1px solid #dbeafe;
    background: #ffffff;
  }
  .mini-box strong {
    display: block;
    margin-bottom: 6px;
    color: #0f172a;
    font-size: 14px;
  }
  .mini-box span {
    display: block;
    color: #475569;
    font-size: 13px;
    line-height: 1.5;
  }
  .demo-lock {
    position: relative;
    min-height: 270px;
    border-radius: 20px;
    background: linear-gradient(180deg, #e5e7eb, #f8fafc);
    overflow: hidden;
  }
  .demo-lock::before {
    content: '';
    position: absolute;
    inset: 16px;
    border-radius: 18px;
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.18), rgba(255, 255, 255, 0.3));
  }
  .demo-panel {
    position: absolute;
    inset: 50% auto auto 50%;
    transform: translate(-50%, -50%);
    width: min(320px, calc(100% - 32px));
    background: #ffffff;
    border-radius: 22px;
    box-shadow: 0 22px 54px rgba(15, 23, 42, 0.16);
    padding: 24px;
    text-align: center;
  }
  .demo-panel h3 {
    margin: 0 0 10px;
    font-size: 23px;
    color: #0f172a;
  }
  .demo-panel p {
    margin: 0 0 16px;
    color: #64748b;
    font-size: 14px;
    line-height: 1.6;
  }
  .token-bar,
  .message-bar {
    border-radius: 16px;
    padding: 18px 20px;
    font-weight: 700;
  }
  .token-bar {
    margin-bottom: 14px;
    color: #ffffff;
    background: linear-gradient(135deg, #1d4ed8, #3b82f6);
    word-break: break-all;
  }
  .message-bar {
    background: #111827;
    color: #ffffff;
  }
  .request-form {
    display: grid;
    gap: 14px;
  }
  .request-form .field {
    padding: 16px 18px;
    border: 1px solid #dbeafe;
    background: #f8fbff;
    border-radius: 16px;
    color: #64748b;
    font-size: 14px;
  }
  .request-button {
    justify-self: start;
    padding: 16px 28px;
    border-radius: 16px;
    background: linear-gradient(135deg, #1d4ed8, #2563eb);
    color: #ffffff;
    font-weight: 700;
  }
  .saas-usecase-copy {
    padding: 58px 54px;
  }
  .saas-usecase-copy-inner {
    max-width: 620px;
  }
  .saas-usecase:nth-child(even) .saas-usecase-copy {
    color: #ffffff;
  }
  .saas-usecase:nth-child(even) .saas-usecase-copy-inner {
    padding: 30px 32px;
    border-radius: 30px;
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.94), rgba(15, 23, 42, 0.82));
    border: 1px solid rgba(96, 165, 250, 0.14);
    box-shadow: 0 24px 60px rgba(2, 6, 23, 0.22);
  }
  .saas-usecase:not(:nth-child(even)) .saas-usecase-copy-inner {
    padding: 30px 32px;
    border-radius: 30px;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid #dbeafe;
    box-shadow: 0 24px 60px rgba(15, 23, 42, 0.08);
  }
  .saas-usecase-label {
    display: inline-block;
    margin-bottom: 16px;
    color: #1d4ed8;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .saas-usecase:nth-child(even) .saas-usecase-label {
    color: #93c5fd;
  }
  .saas-usecase-title {
    margin: 0 0 16px;
    font-size: clamp(2.2rem, 4vw, 3.6rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: inherit;
  }
  .saas-usecase-text {
    margin: 0 0 22px;
    max-width: 460px;
    font-size: 18px;
    line-height: 1.7;
    color: #475569;
  }
  .saas-usecase:nth-child(even) .saas-usecase-text {
    color: rgba(255, 255, 255, 0.8);
  }
  .saas-usecase-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 12px;
  }
  .saas-usecase-list li {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    color: #0f172a;
    font-size: 15px;
    line-height: 1.55;
    font-weight: 600;
  }
  .saas-usecase:nth-child(even) .saas-usecase-list li {
    color: #e5eefc;
  }
  .saas-usecase-list li::before {
    content: '✓';
    width: 22px;
    height: 22px;
    border-radius: 7px;
    background: #2563eb;
    color: #ffffff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 700;
    flex: 0 0 auto;
    margin-top: 1px;
  }
  @media screen and (max-width: 989px) {
    .saas-usecase,
    .saas-usecase:nth-child(even) {
      grid-template-columns: 1fr;
      background: linear-gradient(180deg, #111827 0 34%, #f8fbff 34% 100%);
    }
    .saas-usecase-copy,
    .saas-usecase:nth-child(even) .saas-usecase-copy {
      color: #ffffff;
      order: -1;
    }
    .saas-usecase-copy-inner,
    .saas-usecase:nth-child(even) .saas-usecase-copy-inner,
    .saas-usecase:not(:nth-child(even)) .saas-usecase-copy-inner {
      max-width: none;
      padding: 24px 20px;
      border-radius: 24px;
      background: linear-gradient(135deg, rgba(15, 23, 42, 0.94), rgba(15, 23, 42, 0.82));
      border: 1px solid rgba(96, 165, 250, 0.14);
      box-shadow: 0 24px 60px rgba(2, 6, 23, 0.22);
    }
    .saas-usecase-label,
    .saas-usecase:nth-child(even) .saas-usecase-label {
      color: #93c5fd;
    }
    .saas-usecase-text,
    .saas-usecase:nth-child(even) .saas-usecase-text {
      color: rgba(255, 255, 255, 0.8);
      max-width: none;
    }
    .saas-usecase-list li,
    .saas-usecase:nth-child(even) .saas-usecase-list li {
      color: #e5eefc;
    }
  }
  @media screen and (max-width: 749px) {
    .saas-showcase {
      padding: 76px 0 !important;
    }
    .saas-usecase-media,
    .saas-usecase-copy {
      padding: 24px;
    }
    .mini-row {
      grid-template-columns: 1fr;
    }
    .saas-usecase-title {
      font-size: 38px;
    }
  }
{%- endstyle -%}

<section class="saas-showcase">
  <div class="page-width">
    <div class="saas-showcase-stack">
      <article class="saas-usecase">
        <div class="saas-usecase-media">
          <div class="saas-usecase-demo">
            <div class="demo-header">
              <div class="demo-title">Admin Lock Rule Options</div>
              <div class="demo-pill">Access Rules</div>
            </div>
            <div class="demo-body">
              <div class="mini-row">
                <div class="mini-box"><strong>Scope</strong><span>Products, collections, pages and URLs</span></div>
                <div class="mini-box"><strong>Access</strong><span>Login, passcode, secret link and requests</span></div>
                <div class="mini-box"><strong>Audience</strong><span>Guests, logged-in users, tags and markets</span></div>
                <div class="mini-box"><strong>Action</strong><span>Hide, redirect or replace with message</span></div>
              </div>
            </div>
          </div>
        </div>
        <div class="saas-usecase-copy">
          <div class="saas-usecase-copy-inner">
            <div class="saas-usecase-label">Use Case 01</div>
            <h2 class="saas-usecase-title">Control access to prices, pages and products</h2>
            <p class="saas-usecase-text">Build targeted lock rules for trade pricing, B2B product visibility and private content access from one place.</p>
            <ul class="saas-usecase-list">
              <li>Hide prices and Add to Cart for guest visitors.</li>
              <li>Lock collections, CMS pages and direct product URLs.</li>
              <li>Use AND/OR style rule logic through customer targeting.</li>
            </ul>
          </div>
        </div>
      </article>

      <article class="saas-usecase">
        <div class="saas-usecase-copy">
          <div class="saas-usecase-copy-inner">
            <div class="saas-usecase-label">Use Case 02</div>
            <h2 class="saas-usecase-title">Passcode and private page access</h2>
            <p class="saas-usecase-text">Protect specific pages, campaign links and exclusive collections with clean storefront gates that still feel branded.</p>
            <ul class="saas-usecase-list">
              <li>Require passcode entry before private content is shown.</li>
              <li>Redirect unauthorized visitors or show an access message.</li>
              <li>Keep wholesale resources hidden from regular shoppers.</li>
            </ul>
          </div>
        </div>
        <div class="saas-usecase-media">
          <div class="saas-usecase-demo">
            <div class="demo-header">
              <div class="demo-title">Storefront Locked View</div>
              <div class="demo-pill">Wholesale Gate</div>
            </div>
            <div class="demo-body">
              <div class="demo-lock">
                <div class="demo-panel">
                  <h3>This page is locked</h3>
                  <p>Enter passcode to continue or sign in with an approved account.</p>
                  <div class="message-bar">Unlock with passcode or customer login</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </article>

      <article class="saas-usecase">
        <div class="saas-usecase-media">
          <div class="saas-usecase-demo">
            <div class="demo-header">
              <div class="demo-title">Secret Link & Requests</div>
              <div class="demo-pill">Private Access</div>
            </div>
            <div class="demo-body">
              <div class="token-bar">https://yourstore.com/collections/vip?token=SECRET123</div>
              <div class="message-bar" style="margin-bottom: 16px;">This content is locked. Open with your secret link.</div>
              <div class="request-form">
                <div class="field">Name</div>
                <div class="field">Email</div>
                <div class="field">Message</div>
                <div class="request-button">Send Request</div>
              </div>
            </div>
          </div>
        </div>
        <div class="saas-usecase-copy">
          <div class="saas-usecase-copy-inner">
            <div class="saas-usecase-label">Use Case 03</div>
            <h2 class="saas-usecase-title">Share secret links or collect wholesale requests</h2>
            <p class="saas-usecase-text">Give access through token-based links or collect visitor requests when manual approval is part of your B2B process.</p>
            <ul class="saas-usecase-list">
              <li>Send private URLs to approved distributors and reps.</li>
              <li>Collect name, email and message for wholesale access review.</li>
              <li>Guide buyers into a cleaner quote-first sales workflow.</li>
            </ul>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SaaS Showcase",
  "tag": "section",
  "class": "section",
  "presets": [
    {
      "name": "SaaS Showcase"
    }
  ]
}
{% endschema %}
